<?xml version="1.0" encoding="UTF-8"?>
<phpunit colors="true">
  <testsuites>
    <testsuite name="Backend Tests">
      <directory>tests</directory>
    </testsuite>
  </testsuites>

  <!-- Opcional:  coverage -->
  <coverage processUncoveredFiles="true">
    <include>
      <directory suffix=".php">.</directory>
    </include>
    <exclude>
      <directory>tests</directory>
      <file>phpunit.phar</file>
    </exclude>
  </coverage>

  <php>
    <env name="DB_HOST" value="mysql_test"/>
    <env name="DB_USER" value="root"/>
    <env name="DB_PASS" value="rootpassword"/>
    <env name="DB_NAME" value="hospital_test"/>
    <env name="DB_PORT" value="3306"/>
  </php>
</phpunit>